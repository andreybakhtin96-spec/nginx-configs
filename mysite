upstream redblue {
    server localhost:8083;
    server localhost:8084;
}

server {
    listen 80;
    server_name _;
    
    resolver 8.8.8.8;
    
    root /var/www/mysite;
    index index.html;
    charset utf-8;
    
    location / {
        try_files $uri $uri/ =404;
    }
    
    location /secondpage {
        return 200 "<!DOCTYPE html><html><head><meta charset='UTF-8'><title>Second Page</title></head><body><h1>Вторая страница</h1><p>Обработана тем же nginx</p></body></html>";
        add_header Content-Type text/html;
    }
    
    location /music {
        root /var/www;
        try_files /music/song.mp3 =404;
        add_header Content-Disposition 'attachment; filename="song.mp3"';
    }
    
    location /redblue/ {
        proxy_pass http://redblue/;
        proxy_set_header Host $host;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma "no-cache";
        add_header Expires "0";
    }
    
    location /cpu {
        include fastcgi_params;
        fastcgi_pass unix:/var/run/fcgiwrap.socket;
        fastcgi_param SCRIPT_FILENAME /usr/local/bin/cpu.sh;
    }
    
    location /info.php {
        proxy_pass http://127.0.0.1:8080/info.php;
        proxy_set_header Host $host;
    }
    
    location /secondserver {
        proxy_pass https://api.github.com;
        proxy_set_header Host api.github.com;
    }
    
    location ~ ^/image1/(.*)\.jpg$ {
        alias /var/www/images/$1.jpg;
        image_filter rotate 180;
    }
    
    location ~ ^/image2/(.*)\.png$ {
        alias /var/www/images/$1.png;
    }
}
